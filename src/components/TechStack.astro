---
import SectionHeading from './SectionHeading.astro';
import { techStack } from '../data/tech';

const iconClass = 'h-5 w-5 shrink-0 text-teal-400';
---

<section id="stack" class="border-t border-navy-700/50 px-6 py-20 sm:py-28" aria-labelledby="stack-heading">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      id="stack-heading"
      label="stack"
      title="Tech I ship with"
      description="The toolchain behind my desktop apps, document pipelines, and CI workflows."
    />

    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4" role="list">
      {
        techStack.map((tech) => (
          <li>
            <div class="terminal-border flex h-full flex-col rounded-lg bg-navy-900/40 px-4 py-4 transition-all hover:border-teal-500/25">
              <span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">
                {tech.category}
              </span>
              <div class="mt-1 flex items-center gap-2">
                {tech.icon === 'python' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2C8.1 2 8.4 3.6 8.4 3.6L8.5 5.5h7v1.8h-4.4v1.2h4.3c2 0 3.5 1.7 3.5 3.7 0 2.1-1.6 3.7-3.6 3.7h-2.5v-1.8h2.5c1 0 1.8-.8 1.8-1.9 0-1-.8-1.9-1.8-1.9H8.5v6.2c0 1.5.3 3.2 3.6 3.2 3.1 0 3.4-1.9 3.4-1.9l.1-1.9h-7v-1.8h4.4v-1.2H8.4c-2 0-3.5-1.7-3.5-3.7C4.9 3.7 6.5 2 8.5 2H12z" />
                    <circle cx="10" cy="4.4" r="1" fill="currentColor" opacity="0.5" />
                    <circle cx="14.5" cy="19.2" r="1" fill="currentColor" opacity="0.5" />
                  </svg>
                )}
                {tech.icon === 'pyqt' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="16" rx="2" />
                    <path d="M3 8h18" />
                    <circle cx="6" cy="6" r="0.75" fill="currentColor" stroke="none" />
                    <circle cx="8.5" cy="6" r="0.75" fill="currentColor" stroke="none" />
                    <rect x="7" y="11" width="10" height="6" rx="1" fill="currentColor" opacity="0.25" stroke="none" />
                  </svg>
                )}
                {tech.icon === 'pymupdf' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <path d="M7 3h7l5 5v13a1 1 0 01-1 1H7a1 1 0 01-1-1V4a1 1 0 011-1z" />
                    <path d="M14 3v5h5" />
                    <path d="M8 12h8M8 16h5" stroke-linecap="round" />
                  </svg>
                )}
                {tech.icon === 'ollama' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <circle cx="12" cy="12" r="8" />
                    <circle cx="9" cy="10" r="1.25" fill="currentColor" stroke="none" />
                    <circle cx="15" cy="10" r="1.25" fill="currentColor" stroke="none" />
                    <path d="M9.5 14.5c1 1.5 4 1.5 5 0" stroke-linecap="round" />
                  </svg>
                )}
                {tech.icon === 'openai' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2a7 7 0 00-2.5 13.5v2.2l2.5-1.5 2.5 1.5v-2.2A7 7 0 0012 2zm0 2.2a4.8 4.8 0 110 9.6 4.8 4.8 0 010-9.6z" opacity="0.9" />
                    <path d="M12 6.5c-1.5 1-2.2 2.8-1.8 4.5.5 2 2.5 3.2 4.5 2.7 1.2-.3 2.1-1.1 2.6-2.2" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                )}
                {tech.icon === 'anthropic' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <path d="M12 3L4 19h3.5l1.2-3h7.6l1.2 3H21L12 3z" stroke-linejoin="round" />
                    <path d="M9.5 13.5h5" stroke-linecap="round" />
                  </svg>
                )}
                {tech.icon === 'fastapi' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M13 2L4 14h6l-1 8 10-14h-6l0-6z" />
                  </svg>
                )}
                {tech.icon === 'docker' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <rect x="2" y="10" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.35" stroke="currentColor" />
                    <rect x="6" y="10" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.35" stroke="currentColor" />
                    <rect x="10" y="10" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.35" stroke="currentColor" />
                    <rect x="6" y="6" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.35" stroke="currentColor" />
                    <rect x="10" y="6" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.35" stroke="currentColor" />
                    <path d="M14 13h5c1.5 0 2.5 1 2.5 2.5S20.5 18 19 18H4" stroke-linecap="round" />
                  </svg>
                )}
                {tech.icon === 'github-actions' && (
                  <svg class={iconClass} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <circle cx="6" cy="6" r="2.5" />
                    <circle cx="18" cy="12" r="2.5" />
                    <circle cx="6" cy="18" r="2.5" />
                    <path d="M8.2 7.2L15.8 10.8M8.2 16.8L15.8 13.2" stroke-linecap="round" />
                    <path d="M18 9.5V6.5h3" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
                <span class="font-display text-base font-semibold text-white">{tech.name}</span>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>