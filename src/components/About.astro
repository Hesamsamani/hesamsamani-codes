---
import SectionHeading from './SectionHeading.astro';

const highlights = [
  {
    icon: '🐍',
    title: 'Python-first',
    text: 'Desktop apps with PyQt5/6, document pipelines, and automation that ships as real software.',
  },
  {
    icon: '🤖',
    title: 'Local AI',
    text: 'Ollama and on-device inference — no cloud lock-in, no data leaving your machine.',
  },
  {
    icon: '🔒',
    title: 'Privacy-first',
    text: 'Offline-capable tools built for users who care where their files and models run.',
  },
];
---

<section id="about" class="border-t border-navy-700/50 px-6 py-20 sm:py-28" aria-labelledby="about-heading">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      id="about-heading"
      label="about"
      title="Python & AI tool builder"
      description="I build desktop applications and developer utilities with a focus on local processing, transparent code, and workflows that respect user privacy."
    />

    <div class="mb-12 flex flex-col items-center gap-6 sm:flex-row sm:items-start">
      <div class="terminal-border shrink-0 overflow-hidden rounded-xl shadow-2xl shadow-black/30">
        <img
          src="/images/profile.png"
          alt="Hesam Samani — developer portrait"
          width="320"
          height="320"
          class="h-40 w-40 object-cover object-[center_20%] sm:h-48 sm:w-48"
          loading="lazy"
        />
      </div>
      <p class="max-w-2xl text-base leading-relaxed text-slate-400">
        Open source developer based in Belgium — building privacy-first Python desktop tools,
        document AI pipelines, and utilities that stay on your machine.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-3">
      {
        highlights.map((item) => (
          <article class="terminal-border group rounded-xl bg-navy-900/40 p-6 transition-all hover:border-teal-500/25 hover:bg-navy-800/40">
            <span class="text-2xl" aria-hidden="true">
              {item.icon}
            </span>
            <h3 class="mt-4 font-display text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{item.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>