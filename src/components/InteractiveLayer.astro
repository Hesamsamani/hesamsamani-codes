---
const trackTitle = 'Spring Waltz';
const trackArtist = 'James Quinn';
---

<canvas id="ambient-canvas" class="ambient-canvas" aria-hidden="true"></canvas>
<div id="hero-cursor" class="hero-cursor" aria-hidden="true"></div>
<div id="hero-cursor-dot" class="hero-cursor-dot" aria-hidden="true"></div>

<div class="music-player" data-music-player>
  <button
    type="button"
    class="music-toggle"
    id="music-toggle"
    aria-label="Toggle music player"
    aria-expanded="false"
    aria-controls="music-widget"
  >
    <svg class="music-icon music-icon--note h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z" />
    </svg>
    <svg class="music-icon music-icon--close hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="square" d="M6 6l12 12M18 6L6 18" />
    </svg>
    <span class="music-pulse" aria-hidden="true"></span>
  </button>

  <div class="music-widget" id="music-widget" role="region" aria-label="Background music">
    <audio id="bg-audio" loop preload="auto">
      <source src="/audio/spring-waltz.mp3" type="audio/mpeg" />
    </audio>
    <div class="audio-controls">
      <button type="button" class="audio-play-btn" id="audio-play-btn" aria-label="Play or pause music">
        <svg class="icon-play h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
        <svg class="icon-pause hidden h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6 5h4v14H6zm8 0h4v14h-4z" />
        </svg>
      </button>
      <button type="button" class="audio-progress-wrap" id="audio-progress-wrap" aria-label="Seek track">
        <span class="audio-progress-bar" id="audio-progress-bar"></span>
      </button>
      <span class="audio-time" id="audio-time">0:00</span>
    </div>
    <p class="music-label">{trackTitle} · {trackArtist}</p>
  </div>
</div>

<script src="/scripts/codes-interactive.js" defer></script>