---
interface Props {
  id?: string;
  label: string;
  title: string;
  description?: string;
}

const { id, label, title, description } = Astro.props;
---

<div class="mb-12 max-w-2xl">
  <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-teal-500" id={id}>
    <span class="text-slate-500">//</span> {label}
  </p>
  <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
    {title}
  </h2>
  {
    description && (
      <p class="mt-4 text-base leading-relaxed text-slate-400">{description}</p>
    )
  }
</div>