---
import SectionHeading from './SectionHeading.astro';

const links = [
  {
    label: 'GitHub',
    value: '@Hesamsamani',
    href: 'https://github.com/Hesamsamani',
    description: 'Source code, issues, and contributions',
  },
  {
    label: 'Professional site',
    value: 'hesamsamani.me',
    href: 'https://hesamsamani.me',
    description: 'Resume, experience, and business inquiries',
  },
  {
    label: 'Email',
    value: 'hello@hesamsamani.codes',
    href: 'mailto:hello@hesamsamani.codes',
    description: 'Direct contact for collaborations',
  },
];
---

<section id="contact" class="border-t border-navy-700/50 px-6 py-20 sm:py-28" aria-labelledby="contact-heading">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      id="contact-heading"
      label="contact"
      title="Let's connect"
      description="Open to collaboration on open source tools, Python desktop apps, and AI-powered utilities."
    />

    <ul class="grid gap-4 sm:grid-cols-3" role="list">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              class="terminal-border group flex h-full flex-col rounded-xl bg-navy-900/40 p-6 transition-all hover:border-teal-500/30 hover:bg-navy-800/40"
            >
              <span class="font-mono text-xs uppercase tracking-widest text-slate-500">
                {link.label}
              </span>
              <span class="mt-2 font-display text-lg font-semibold text-white transition-colors group-hover:text-teal-400">
                {link.value}
              </span>
              <span class="mt-2 text-sm text-slate-500">{link.description}</span>
              <span class="mt-4 font-mono text-xs text-teal-500 opacity-0 transition-opacity group-hover:opacity-100">
                open ↗
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>