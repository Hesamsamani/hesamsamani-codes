---
const items = [
  {
    title: 'PDF Intelligence',
    description: 'Multi-engine extraction pipelines with optional local LLM enrichment via Ollama.',
    href: 'https://github.com/Hesamsamani/Distilmark',
    tag: 'Distilmark',
  },
  {
    title: 'Offline Learning',
    description: 'Desktop tools that keep course materials on your machine — no subscriptions required.',
    href: 'https://github.com/Hesamsamani/CourseraGrab',
    tag: 'CourseraGrab',
  },
  {
    title: 'Privacy-First UX',
    description: 'PyQt interfaces designed for long sessions — dark mode, keyboard flows, zero telemetry.',
    href: 'https://github.com/Hesamsamani',
    tag: 'Design',
  },
  {
    title: 'BIM Portfolio',
    description: 'Professional Revit and healthcare BIM work — see the recruiter-facing site.',
    href: 'https://hesamsamani.me',
    tag: 'hesamsamani.me',
  },
];
---

<section id="explore" class="border-t border-navy-700/50 px-6 py-20 sm:py-28" aria-labelledby="explore-heading">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 max-w-2xl">
      <p class="mb-3 font-mono text-xs uppercase tracking-[0.25em] text-teal-500">Sandbox</p>
      <h2 id="explore-heading" class="font-display text-3xl font-bold text-white sm:text-4xl">
        Things I build & explore
      </h2>
      <p class="mt-4 text-slate-400">
        Side projects, open source utilities, and cross-links between my developer and professional portfolios.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        items.map((item) => (
          <a
            href={item.href}
            target={item.href.startsWith('https://hesamsamani.me') ? undefined : '_blank'}
            rel={item.href.startsWith('https://hesamsamani.me') ? undefined : 'noopener noreferrer'}
            class="terminal-border group rounded-xl bg-navy-900/50 p-6 transition-all hover:border-teal-500/30 hover:bg-navy-800/60"
          >
            <span class="font-mono text-[10px] uppercase tracking-widest text-teal-500/80">{item.tag}</span>
            <h3 class="mt-3 font-display text-xl font-semibold text-white group-hover:text-teal-300">
              {item.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{item.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 font-mono text-xs text-teal-400">
              Discover more <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>