---
const commands = [
  { prompt: 'whoami', output: 'hesam_samani' },
  { prompt: 'role --describe', output: 'python · ai · desktop tools' },
  { prompt: 'philosophy', output: 'privacy-first · local-first · open source' },
];
---

<section class="relative overflow-hidden px-6 pb-20 pt-16 sm:pb-28 sm:pt-24" aria-labelledby="hero-heading" data-hero-section>
  <canvas id="hero-particle-canvas" class="hero-particle-canvas" aria-hidden="true"></canvas>
  <div class="relative z-10 mx-auto max-w-6xl">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <div>
        <p class="mb-6 font-mono text-xs uppercase tracking-[0.25em] text-teal-500">
          <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-teal-400" aria-hidden="true"></span>
          <span class="ml-2">Open source developer</span>
        </p>

        <h1
          id="hero-heading"
          class="font-display text-4xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl"
        >
          Building AI tools that<br />
          <span class="text-gradient">save people time.</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
          Python desktop apps and privacy-first utilities — PDF converters, offline
          downloaders, and open source software that stays on your machine.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3" role="list" aria-label="Social links">
          <a href="https://github.com/Hesamsamani" target="_blank" rel="noopener noreferrer" class="social-link" role="listitem" aria-label="GitHub">
            <span class="text-slate-500">gh</span> GitHub
          </a>
          <a href="https://www.linkedin.com/in/hesam-samani/" target="_blank" rel="noopener noreferrer" class="social-link" role="listitem" aria-label="LinkedIn">
            <span class="text-slate-500">in</span> LinkedIn
          </a>
          <a href="https://hesamsamani.me" class="social-link" role="listitem" aria-label="Professional portfolio">
            <span class="text-slate-500">me</span> BIM Portfolio
          </a>
        </div>

        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="#projects"
            data-magnetic
            class="glow-teal inline-flex items-center gap-2 rounded-lg bg-teal-500 px-6 py-3 font-mono text-sm font-medium text-navy-950 transition-all hover:bg-teal-400"
          >
            View projects
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="https://github.com/Hesamsamani"
            target="_blank"
            rel="noopener noreferrer"
            class="terminal-border inline-flex items-center gap-2 rounded-lg bg-navy-800/50 px-6 py-3 font-mono text-sm text-slate-300 transition-all hover:border-teal-500/30 hover:text-teal-400"
          >
            GitHub
            <span class="text-slate-500" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <div
        class="terminal-border scanline relative overflow-hidden rounded-xl bg-navy-900/80 p-0 shadow-2xl shadow-black/40"
        role="region"
        aria-label="Terminal preview"
      >
        <div class="flex items-center gap-2 border-b border-navy-600/60 px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-red-500/70" aria-hidden="true"></span>
          <span class="h-3 w-3 rounded-full bg-amber-400/70" aria-hidden="true"></span>
          <span class="h-3 w-3 rounded-full bg-teal-500/70" aria-hidden="true"></span>
          <span class="ml-2 font-mono text-xs text-slate-500">hesam@dev ~ zsh</span>
        </div>
        <div class="space-y-4 p-5 font-mono text-sm leading-relaxed">
          {
            commands.map((cmd) => (
              <div>
                <p>
                  <span class="text-teal-500">❯</span>{' '}
                  <span class="text-cyan-400">{cmd.prompt}</span>
                </p>
                <p class="mt-1 pl-4 text-slate-400">{cmd.output}</p>
              </div>
            ))
          }
          <p class="flex items-center gap-1">
            <span class="text-teal-500">❯</span>
            <span class="inline-block h-4 w-2 animate-pulse bg-teal-400/80" aria-hidden="true"></span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>